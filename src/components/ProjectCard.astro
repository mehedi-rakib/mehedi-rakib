---
import type { Project } from '../data/portfolio';
interface Props { project: Project }
const { project } = Astro.props;
const primaryLink = project.links[0];
---
<article class={`project ${project.tone}`}>
  <div class="project-copy reveal d1">
    <p class="project-meta"><span>{project.id}</span><span>{project.type}</span></p>
    <h3>{project.name}</h3>
    <p class="project-summary">{project.summary}</p>

    {(project.problem || project.solution || project.impact) && (
      <div class="case-study">
        {project.problem && (
          <div class="cs-row">
            <span class="cs-label">The Problem</span>
            <p>{project.problem}</p>
          </div>
        )}
        {project.solution && (
          <div class="cs-row">
            <span class="cs-label">The Solution</span>
            <p>{project.solution}</p>
          </div>
        )}
        {project.impact && (
          <div class="cs-impact">
            <span class="cs-label">Business Impact</span>
            <p>{project.impact}</p>
          </div>
        )}
      </div>
    )}

    <div class="project-facts">
      <div><span>My role</span><p>{project.role}</p></div>
      <div><span>Status</span><p>{project.status}</p></div>
    </div>
    <ul>{project.tags.map(tag => <li>{tag}</li>)}</ul>
    <div class="project-links">
      {project.caseStudySlug && (
        <a class="cs-link" href={`/case-study/${project.caseStudySlug}`}>Read case study →</a>
      )}
      {project.links.map(link => <a href={link.href} target="_blank">{link.label} ↗</a>)}
    </div>
  </div>
  <a class="project-visual reveal-left" data-tilt href={primaryLink?.href} target="_blank" aria-label={`Visit ${project.name}`}>
    <div class="browser-chrome"><i></i><i></i><i></i><span>{project.name.toLowerCase().replaceAll(' ', '')}.product</span></div>
    <div class="project-image-clip">
      {project.image ? <img class="project-image" src={project.image} alt={`${project.name} project interface`} loading="lazy" width="1600" height="1000"/> : <div class="image-placeholder"><span>PROJECT IMAGE</span><small>1600 × 1000 px · WebP</small></div>}
    </div>
    <span class="view">Visit live ↗</span>
  </a>
</article>

<style>
  .project-summary {
    color: #b7b8af;
    line-height: 1.6;
    font-size: 17px;
    margin: 0;
  }

  /* ── Case Study Block ── */
  .case-study {
    margin-top: 28px;
    border-top: 1px solid #3b3c38;
  }

  .cs-row {
    padding: 14px 0;
    border-bottom: 1px solid #292a27;
  }

  .cs-label {
    display: block;
    margin-bottom: 6px;
    color: #777a73;
    font: 9px 'DM Mono', monospace;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .cs-row p {
    margin: 0;
    color: #b7b8af;
    font-size: 13px;
    line-height: 1.6;
    padding-left: 14px;
    border-left: 2px solid #3b3c38;
  }

  .cs-impact {
    margin-top: 2px;
    padding: 14px 16px;
    background: rgba(200, 255, 0, 0.06);
    border-left: 3px solid #c8ff00;
  }

  .cs-impact .cs-label {
    color: #8ab800;
  }

  .cs-impact p {
    margin: 0;
    color: #d4d5cc;
    font-size: 13px;
    line-height: 1.6;
    font-weight: 500;
  }

  /* ── Project Meta ── */
  .project-facts {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    margin-top: 28px;
    padding-top: 22px;
    border-top: 1px solid #3b3c38;
  }

  .project-facts span {
    display: block;
    margin-bottom: 8px;
    color: #777a73;
    font: 9px 'DM Mono', monospace;
    letter-spacing: .08em;
    text-transform: uppercase;
  }

  .project-facts p {
    margin: 0;
    color: #f1efe8;
    font-size: 12px;
    line-height: 1.5;
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 25px;
  }

  .project-links a {
    padding-bottom: 6px;
    color: #f1efe8;
    border-bottom: 1px solid #777;
    font: 10px 'DM Mono', monospace;
    text-transform: uppercase;
    transition: border-color 0.2s, color 0.2s;
  }

  .project-links a:hover {
    color: #c8ff00;
    border-color: #c8ff00;
  }

  .project-links .cs-link {
    padding: 7px 14px;
    border-bottom: none;
    background: rgba(200, 255, 0, 0.1);
    color: #c8ff00;
    border: 1px solid rgba(200, 255, 0, 0.28);
    font-weight: 600;
    letter-spacing: 0.04em;
    transition: background 0.2s, border-color 0.2s;
  }
  .project-links .cs-link:hover {
    background: rgba(200, 255, 0, 0.2);
    border-color: #c8ff00;
    color: #c8ff00;
  }

  @media (max-width: 800px) {
    .project-facts { grid-template-columns: 1fr; }
    .cs-impact { padding: 12px; }
  }
</style>
