<div class="page-loader" id="pageLoader" aria-hidden="true">
  <div class="loader-inner">
    <div class="loader-brand">R<span>•</span></div>
    <div class="loader-bar-wrap"><div class="loader-bar"></div></div>
  </div>
</div>
<div class="progress" aria-hidden="true"></div>
<div class="cursor" aria-hidden="true"></div>

<script>
  import Lenis from 'lenis';

  /* ── Smooth scroll (Lenis) ───────────────────────────── */
  const lenis = new Lenis({
    duration: 1.15,
    easing: (t: number) => 1 - Math.pow(1 - t, 4),
    smoothWheel: true,
    touchMultiplier: 1.8,
  });

  function raf(time: number) {
    lenis.raf(time);
    requestAnimationFrame(raf);
  }
  requestAnimationFrame(raf);

  /* Anchor links — let Lenis handle smooth scroll to hash targets */
  document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach(a => {
    a.addEventListener('click', e => {
      const id = a.getAttribute('href');
      if (!id || id === '#') return;
      const target = document.querySelector(id);
      if (!target) return;
      e.preventDefault();
      lenis.scrollTo(target as HTMLElement, { offset: -80, duration: 1.4 });
    });
  });

  /* ── Page loader ─────────────────────────────────────── */
  const loader = document.getElementById('pageLoader') as HTMLElement | null;
  const hideLoader = () => loader?.classList.add('done');
  if (document.readyState === 'complete') {
    setTimeout(hideLoader, 600);
  } else {
    window.addEventListener('load', () => setTimeout(hideLoader, 600));
  }

  /* ── Progress bar ────────────────────────────────────── */
  const progress = document.querySelector<HTMLElement>('.progress');
  const updateProgress = () => {
    if (!progress) return;
    const max = document.documentElement.scrollHeight - innerHeight;
    progress.style.transform = `scaleX(${max > 0 ? scrollY / max : 0})`;
  };
  addEventListener('scroll', updateProgress, { passive: true });
  updateProgress();

  /* ── Scroll reveal (all variants) ────────────────────── */
  const revealObserver = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      entry.target.classList.add('is-visible');
      revealObserver.unobserve(entry.target);
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale')
    .forEach(el => revealObserver.observe(el));

  /* ── Number counter animation ────────────────────────── */
  const countObserver = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const target = parseFloat(el.dataset.count ?? '0');
      const suffix = el.dataset.suffix ?? '';
      const prefix = el.dataset.prefix ?? '';
      const duration = 1600;
      let t0: number | null = null;
      const step = (ts: number) => {
        if (!t0) t0 = ts;
        const p = Math.min((ts - t0) / duration, 1);
        const eased = 1 - (1 - p) ** 3;
        el.textContent = prefix + (Number.isInteger(target) ? Math.floor(eased * target) : (eased * target).toFixed(1)) + suffix;
        if (p < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
      countObserver.unobserve(el);
    });
  }, { threshold: 0.5 });

  document.querySelectorAll<HTMLElement>('[data-count]').forEach(el => countObserver.observe(el));

  /* ── Project image scroll-rise parallax ─────────────── */
  const projectClips = document.querySelectorAll<HTMLElement>('.project-image-clip');

  const updateProjectParallax = () => {
    const vh = window.innerHeight;
    projectClips.forEach(clip => {
      const img = clip.querySelector<HTMLElement>('.project-image');
      if (!img) return;
      const rect = clip.getBoundingClientRect();
      // 0 = clip bottom at viewport bottom, 1 = clip center at viewport center
      const raw = (vh - rect.top) / (vh * 0.65 + rect.height * 0.5);
      const t = Math.max(0, Math.min(1, raw));
      // Ease out quart
      const eased = 1 - Math.pow(1 - t, 4);
      const y = 90 * (1 - eased);
      const scale = 1 + 0.08 * (1 - eased);
      img.style.transform = `translateY(${y}px) scale(${scale})`;
    });
  };

  // Set initial state before first paint
  projectClips.forEach(clip => {
    const img = clip.querySelector<HTMLElement>('.project-image');
    if (img) img.style.transform = 'translateY(90px) scale(1.08)';
  });

  addEventListener('scroll', updateProjectParallax, { passive: true });
  updateProjectParallax();

  /* ── Hero parallax ───────────────────────────────────── */
  const heroImg = document.querySelector<HTMLElement>('.hero-photo img');
  if (heroImg) {
    addEventListener('scroll', () => {
      if (scrollY < innerHeight * 1.4) {
        heroImg.style.transform = `translateY(${scrollY * 0.09}px)`;
      }
    }, { passive: true });
  }

  /* ── Cursor + interactions ───────────────────────────── */
  const cursor = document.querySelector<HTMLElement>('.cursor');
  if (matchMedia('(pointer:fine)').matches && cursor) {
    addEventListener('pointermove', e => {
      cursor.style.transform = `translate3d(${e.clientX}px,${e.clientY}px,0)`;
    });

    document.querySelectorAll('a,[data-tilt]').forEach(el => {
      el.addEventListener('mouseenter', () => cursor.classList.add('active'));
      el.addEventListener('mouseleave', () => cursor.classList.remove('active'));
    });

    /* Magnetic round-link */
    document.querySelectorAll<HTMLElement>('.round-link').forEach(btn => {
      btn.addEventListener('mousemove', e => {
        const r = btn.getBoundingClientRect();
        const x = (e.clientX - r.left - r.width / 2) * 0.22;
        const y = (e.clientY - r.top - r.height / 2) * 0.22;
        btn.style.transform = `translate(${x}px,${y}px) rotate(-8deg)`;
        btn.style.background = 'var(--ink)';
        btn.style.color = 'var(--lime)';
      });
      btn.addEventListener('mouseleave', () => {
        btn.style.transform = '';
        btn.style.background = '';
        btn.style.color = '';
      });
    });

    /* Magnetic contact CTA */
    document.querySelectorAll<HTMLElement>('.contact-cta').forEach(el => {
      el.addEventListener('mousemove', e => {
        const r = el.getBoundingClientRect();
        const x = (e.clientX - r.left - r.width / 2) * 0.04;
        const y = (e.clientY - r.top - r.height / 2) * 0.15;
        el.style.transform = `translate(${x}px,${y}px)`;
      });
      el.addEventListener('mouseleave', () => { el.style.transform = ''; });
    });

    /* 3-D tilt on project cards */
    document.querySelectorAll<HTMLElement>('[data-tilt]').forEach(card => {
      card.addEventListener('pointermove', e => {
        const b = card.getBoundingClientRect();
        const x = (e.clientX - b.left) / b.width - 0.5;
        const y = (e.clientY - b.top) / b.height - 0.5;
        card.style.transform =
          `perspective(900px) rotateX(${-y * 3}deg) rotateY(${x * 4}deg) translateY(-6px)`;
        card.style.setProperty('--mx', `${(x + 0.5) * 100}%`);
        card.style.setProperty('--my', `${(y + 0.5) * 100}%`);
      });
      card.addEventListener('pointerleave', () => { card.style.transform = ''; });
    });

    /* Process step – subtle hover tilt */
    document.querySelectorAll<HTMLElement>('.process-step').forEach(step => {
      step.addEventListener('mousemove', e => {
        const r = step.getBoundingClientRect();
        const x = (e.clientX - r.left) / r.width - 0.5;
        step.style.transform = `skewY(${x * 0.5}deg)`;
      });
      step.addEventListener('mouseleave', () => { step.style.transform = ''; });
    });
  }

  /* ── Skill row water — cursor light tracking ─────────── */
  document.querySelectorAll<HTMLElement>('.skill-row').forEach(row => {
    row.addEventListener('mousemove', e => {
      const rect = row.getBoundingClientRect();
      const x = ((e.clientX - rect.left) / rect.width) * 100;
      row.style.setProperty('--mx', `${x}%`);
    });
  });
</script>
