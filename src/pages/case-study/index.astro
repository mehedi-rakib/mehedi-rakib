---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { caseStudies } from '../../data/case-studies';
---

<Layout title="Case Studies — Rakib" description="In-depth stories behind the products I've shipped — from the problem, to the build, to production.">
  <Header base="/" />

  <div class="csi-page">

    <section class="csi-hero shell">
      <p class="eyebrow">Case Studies</p>
      <h1>Behind the<br/><em>products I've shipped.</em></h1>
      <p class="csi-sub">Not just what I built — why I built it, how I made decisions, and what I learned shipping to real users.</p>
    </section>

    <div class="csi-grid shell">
      {caseStudies.map((cs, i) => (
        <a class="csi-card" href={`/case-study/${cs.slug}`}>
          <div class="csi-card-inner">
            <div class="csi-card-left">
              <span class="csi-num">0{i + 1}</span>
              <div class="csi-tags">
                {cs.tags.slice(0, 3).map(tag => <span>{tag}</span>)}
              </div>
              <h2>{cs.title}</h2>
              <p>{cs.tagline}</p>
              <div class="csi-meta">
                <span>{cs.status}</span>
              </div>
            </div>
            {cs.image && (
              <div class="csi-card-image">
                <img src={cs.image} alt={cs.title} width="800" height="500" loading="lazy" />
              </div>
            )}
          </div>
          <div class="csi-card-foot">
            <span class="csi-read">Read case study →</span>
            <span class="csi-role">{cs.role}</span>
          </div>
        </a>
      ))}
    </div>

    <div class="csi-back shell">
      <a href="/#work">← Back to all projects</a>
    </div>

  </div>
</Layout>

<style>
  .csi-page {
    min-height: 100vh;
    background: var(--paper);
    color: var(--ink);
    padding-bottom: 120px;
  }

  /* ── Hero ── */
  .csi-hero {
    padding: clamp(60px, 8vw, 120px) 0 clamp(48px, 6vw, 80px);
    border-bottom: 1px solid rgba(16, 17, 15, 0.1);
    margin-bottom: 0;
  }

  .csi-hero .eyebrow {
    font: 10px 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #888;
    margin: 0 0 20px;
  }

  .csi-hero h1 {
    font-size: clamp(36px, 5.5vw, 72px);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.035em;
    margin: 0 0 24px;
  }

  .csi-hero h1 em {
    font-style: italic;
    font-weight: 400;
  }

  .csi-sub {
    max-width: 560px;
    font-size: clamp(15px, 1.2vw, 18px);
    line-height: 1.7;
    color: #4a4b46;
    margin: 0;
  }

  /* ── Grid ── */
  .csi-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* ── Card ── */
  .csi-card {
    display: block;
    padding: clamp(36px, 4vw, 64px) 0;
    border-bottom: 1px solid rgba(16, 17, 15, 0.1);
    text-decoration: none;
    color: var(--ink);
    transition: background 0.25s;
    margin: 0 calc(-1 * clamp(20px, 4vw, 80px));
    padding-left: clamp(20px, 4vw, 80px);
    padding-right: clamp(20px, 4vw, 80px);
  }
  .csi-card:hover { background: rgba(16, 17, 15, 0.025); }

  .csi-card-inner {
    display: grid;
    grid-template-columns: 1fr clamp(240px, 32%, 400px);
    gap: clamp(32px, 5vw, 80px);
    align-items: center;
    margin-bottom: 28px;
  }

  .csi-num {
    display: block;
    font: 700 11px 'DM Mono', monospace;
    letter-spacing: 0.1em;
    color: #aaa;
    margin-bottom: 16px;
  }

  .csi-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 20px;
  }

  .csi-tags span {
    padding: 4px 10px;
    font: 500 9px 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border: 1px solid rgba(16, 17, 15, 0.18);
    color: #666;
  }

  .csi-card h2 {
    font-size: clamp(22px, 2.2vw, 34px);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.15;
    margin: 0 0 16px;
  }

  .csi-card-left > p {
    font-size: clamp(14px, 1.1vw, 16px);
    line-height: 1.7;
    color: #555;
    margin: 0 0 20px;
    max-width: 540px;
  }

  .csi-meta span {
    font: 500 10px 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: #888;
  }

  .csi-card-image {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #e5e2db;
  }

  .csi-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    filter: saturate(0.82) contrast(1.03);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .csi-card:hover .csi-card-image img { transform: scale(1.04); }

  .csi-card-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 20px;
    border-top: 1px solid rgba(16, 17, 15, 0.08);
  }

  .csi-read {
    font: 600 12px 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink);
    transition: letter-spacing 0.25s;
  }
  .csi-card:hover .csi-read { letter-spacing: 0.1em; }

  .csi-role {
    font: 400 11px 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #aaa;
  }

  /* ── Back link ── */
  .csi-back {
    margin-top: 64px;
  }

  .csi-back a {
    font: 500 12px 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #888;
    transition: color 0.2s;
  }
  .csi-back a:hover { color: var(--ink); }

  /* ── Mobile ── */
  @media (max-width: 700px) {
    .csi-card-inner { grid-template-columns: 1fr; }
    .csi-card-image { display: none; }
    .csi-role { display: none; }
  }
</style>
