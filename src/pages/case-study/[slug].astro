---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { caseStudies } from '../../data/case-studies';
import type { CaseStudy } from '../../data/case-studies';

export function getStaticPaths() {
  return caseStudies.map(cs => ({
    params: { slug: cs.slug },
    props: { cs },
  }));
}

interface Props { cs: CaseStudy }
const { cs } = Astro.props;


---

<Layout title={`${cs.title} — Rakib`} description={cs.tagline}>
  <Header base="/" />

  <div class="cs-page">

    <!-- Hero -->
    <section class="cs-hero">
      <div class="cs-hero-inner">
        <div class="cs-breadcrumb">
          <a href="/case-study">Case Studies</a>
          <span>/</span>
          <span>{cs.title}</span>
        </div>
        <div class="cs-meta-row">
          {cs.tags.map(tag => <span class="cs-tag">{tag}</span>)}
        </div>
        <h1>{cs.title}</h1>
        <p class="cs-tagline">{cs.tagline}</p>
        <div class="cs-info-strip">
          <div><span>Role</span><p>{cs.role}</p></div>
          <div><span>Status</span><p>{cs.status}</p></div>
          {cs.links.map(link => (
            <div>
              <span>Live link</span>
              <p><a href={link.href} target="_blank" rel="noopener">{link.label} ↗</a></p>
            </div>
          ))}
        </div>
      </div>
      {cs.image && (
        <div class="cs-hero-image">
          <img src={cs.image} alt={cs.title} width="1600" height="1000" loading="eager" />
        </div>
      )}
    </section>

    <!-- Body -->
    <div class="cs-body">
      <aside class="cs-sidebar">
        <nav aria-label="Case study sections" id="cs-toc">
          <p class="cs-sidebar-label">Contents</p>
          <ol>
            <li><a href="#intro" data-section="intro">Introduction</a></li>
            {cs.sections.map(s => {
              const id = s.heading.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
              return (
                <li><a href={`#${id}`} data-section={id}>{s.heading}</a></li>
              );
            })}
            <li><a href="#closing" data-section="closing">Closing thoughts</a></li>
          </ol>
        </nav>
      </aside>

      <article class="cs-content">
        <!-- Intro -->
        <div class="cs-section" id="intro">
          <p class="cs-intro">{cs.intro}</p>
        </div>

        <!-- Sections -->
        {cs.sections.map(section => {
          const id = section.heading.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
          return (
            <div class="cs-section" id={id}>
              <h2>{section.heading}</h2>
              {section.paragraphs.map(p => <p>{p}</p>)}
              {section.pullQuote && (
                <blockquote class="cs-quote">
                  <p>{section.pullQuote}</p>
                </blockquote>
              )}
            </div>
          );
        })}

        <!-- Closing -->
        <div class="cs-section cs-closing" id="closing">
          <p>{cs.closingStatement}</p>
        </div>

        <!-- CTA -->
        <div class="cs-cta-row">
          {cs.links.map(link => (
            <a class="cs-cta-primary" href={link.href} target="_blank" rel="noopener">
              {link.label} ↗
            </a>
          ))}
          <a class="cs-cta-secondary" href="/case-study">← All case studies</a>
        </div>
      </article>
    </div>

  </div>
</Layout>

<script>
  /* ── Active sidebar section highlight ── */
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('#cs-toc a[data-section]');
  const sections = document.querySelectorAll<HTMLElement>('.cs-section[id]');

  function setActive(id: string) {
    tocLinks.forEach(a => {
      const isActive = a.dataset.section === id;
      a.classList.toggle('is-active', isActive);
    });
  }

  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        setActive(entry.target.id);
      }
    });
  }, {
    rootMargin: '-10% 0px -82% 0px',
    threshold: 0,
  });

  sections.forEach(s => observer.observe(s));

  /* Smooth scroll to section on sidebar link click */
  tocLinks.forEach(link => {
    link.addEventListener('click', e => {
      e.preventDefault();
      const id = link.dataset.section;
      const target = id ? document.getElementById(id) : null;
      if (target) {
        const offset = 100;
        const top = target.getBoundingClientRect().top + window.scrollY - offset;
        window.scrollTo({ top, behavior: 'smooth' });
      }
    });
  });
</script>

<style>
  .cs-page {
    min-height: 100vh;
    background: var(--paper);
    color: var(--ink);
  }

  /* ── Breadcrumb ── */
  .cs-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 24px;
    font: 11px 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #888;
  }
  .cs-breadcrumb a { color: #888; transition: color 0.2s; }
  .cs-breadcrumb a:hover { color: var(--ink); }
  .cs-breadcrumb span:last-child {
    color: var(--ink);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 320px;
  }

  /* ── Hero ── */
  .cs-hero {
    padding: clamp(40px, 6vw, 100px) clamp(20px, 5vw, 80px) 0;
    max-width: 1200px;
    margin: 0 auto;
  }

  .cs-hero-inner { max-width: 820px; }

  .cs-meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 28px;
  }

  .cs-tag {
    padding: 5px 12px;
    font: 500 10px 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    border: 1px solid rgba(16, 17, 15, 0.2);
    background: rgba(16, 17, 15, 0.04);
  }

  .cs-hero h1 {
    font-size: clamp(30px, 4.5vw, 60px);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin: 0 0 20px;
  }

  .cs-tagline {
    font-size: clamp(16px, 1.4vw, 20px);
    line-height: 1.65;
    color: #4a4b46;
    margin: 0 0 40px;
    max-width: 680px;
  }

  .cs-info-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    border-top: 1px solid rgba(16, 17, 15, 0.12);
    border-bottom: 1px solid rgba(16, 17, 15, 0.12);
    margin-bottom: 56px;
  }

  .cs-info-strip > div {
    padding: 18px 32px 18px 0;
    margin-right: 32px;
    border-right: 1px solid rgba(16, 17, 15, 0.1);
  }
  .cs-info-strip > div:last-child { border-right: none; margin-right: 0; }

  .cs-info-strip span {
    display: block;
    font: 9px 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #888;
    margin-bottom: 6px;
  }

  .cs-info-strip p {
    margin: 0;
    font-size: 13px;
    font-weight: 500;
    color: var(--ink);
  }

  .cs-info-strip a {
    color: var(--ink);
    border-bottom: 1px solid rgba(16, 17, 15, 0.3);
    transition: color 0.2s, border-color 0.2s;
  }
  .cs-info-strip a:hover { color: #5e8500; border-color: #5e8500; }

  .cs-hero-image {
    width: 100%;
    max-width: 1200px;
    aspect-ratio: 16 / 7;
    overflow: hidden;
    background: #e5e2db;
  }

  .cs-hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    filter: saturate(0.85) contrast(1.03);
  }

  /* ── Body layout ── */
  .cs-body {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 0;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(20px, 5vw, 80px);
    align-items: start;
  }

  /* ── Sidebar ── */
  .cs-sidebar {
    position: sticky;
    top: 80px;
    padding: 56px 40px 56px 0;
    border-right: 1px solid rgba(16, 17, 15, 0.1);
  }

  .cs-sidebar-label {
    font: 9px 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #888;
    margin: 0 0 16px;
  }

  .cs-sidebar ol {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .cs-sidebar a {
    display: block;
    padding: 7px 0 7px 14px;
    font-size: 12px;
    line-height: 1.4;
    color: #aaa;
    border-left: 2px solid transparent;
    margin-left: -2px;
    transition: color 0.2s, border-color 0.2s;
  }
  .cs-sidebar a:hover {
    color: var(--ink);
    border-left-color: rgba(16, 17, 15, 0.3);
  }
  .cs-sidebar a.is-active {
    color: var(--ink);
    border-left-color: var(--ink);
    font-weight: 600;
  }

  /* ── Content ── */
  .cs-content {
    padding: 56px 0 80px 64px;
    max-width: 720px;
  }

  .cs-section {
    margin-bottom: 64px;
  }

  .cs-intro {
    font-size: clamp(18px, 1.5vw, 22px);
    line-height: 1.7;
    font-weight: 400;
    color: #2a2b27;
    margin: 0;
    padding-bottom: 48px;
    border-bottom: 1px solid rgba(16, 17, 15, 0.1);
  }

  .cs-section h2 {
    font-size: clamp(20px, 1.8vw, 28px);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 22px;
    line-height: 1.2;
  }

  .cs-section p {
    font-size: clamp(15px, 1.1vw, 17px);
    line-height: 1.82;
    color: #3a3b37;
    margin: 0 0 20px;
  }
  .cs-section p:last-of-type { margin-bottom: 0; }

  .cs-quote {
    margin: 36px 0;
    padding: 28px 32px;
    border-left: 3px solid var(--lime);
    background: rgba(200, 255, 0, 0.06);
  }

  .cs-quote p {
    margin: 0;
    font-size: clamp(16px, 1.2vw, 19px);
    font-weight: 600;
    font-style: italic;
    line-height: 1.6;
    color: var(--ink);
  }

  .cs-closing {
    padding: 40px;
    background: var(--ink);
    color: var(--paper);
    margin-top: 80px;
  }

  .cs-closing p {
    color: rgba(241, 239, 232, 0.85);
    font-size: clamp(15px, 1.1vw, 17px);
    line-height: 1.82;
    margin: 0;
  }

  /* ── CTA row ── */
  .cs-cta-row {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-top: 56px;
    flex-wrap: wrap;
  }

  .cs-cta-primary {
    display: inline-flex;
    align-items: center;
    padding: 14px 28px;
    background: var(--ink);
    color: var(--paper);
    font: 600 13px 'Manrope', sans-serif;
    letter-spacing: 0.02em;
    transition: background 0.2s, color 0.2s;
  }
  .cs-cta-primary:hover { background: var(--lime); color: var(--ink); }

  .cs-cta-secondary {
    font: 500 12px 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink);
    opacity: 0.55;
    transition: opacity 0.2s;
  }
  .cs-cta-secondary:hover { opacity: 1; }

  /* ── Mobile ── */
  @media (max-width: 860px) {
    .cs-body { grid-template-columns: 1fr; }
    .cs-sidebar { display: none; }
    .cs-content { padding: 40px 0 60px; max-width: 100%; }
    .cs-info-strip > div { padding: 14px 20px 14px 0; margin-right: 20px; }
    .cs-hero-image { aspect-ratio: 16 / 9; }
  }
</style>
